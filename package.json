{
  "name": "food-haven",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:food-haven": "node dist/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
