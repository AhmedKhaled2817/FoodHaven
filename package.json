    "@angular/compiler-cli": "^21.0.0",
    "@types/aos": "^3.0.8",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
